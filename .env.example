# ── Base de dados (PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/psn?schema=public"

# ── Sessões / Segurança ──────────────────────────────────────────────────────
# Chave de assinatura dos tokens de sessão (mínimo 32 caracteres aleatórios).
# Gere uma nova com:  openssl rand -base64 48
SESSION_SECRET="troque-esta-chave-por-uma-aleatoria-com-pelo-menos-32-caracteres"

# Duração da sessão em segundos (por omissão 8 horas)
SESSION_MAX_AGE="28800"

# ── Integrações externas (preparadas, ligadas em fase posterior) ─────────────
# Serviço de Identificação Civil (SIAC) — carregamento automático de dados por BI
SIAC_API_URL=""
SIAC_API_KEY=""

# ── Pagamentos: Pay4all (é+ / é-Kwanza) ──────────────────────────────────────
# Gateway do parceiro Pay4all, S.A. (Grupo BAI). Canais: Multicaixa Express,
# Referência EMIS e é-Kwanza (QR). Credenciais e URL fornecidas após a adesão
# (b2b@pay4all.ao). Sem estas variáveis o portal opera em modo simulado.
PAY4ALL_API_URL=""
PAY4ALL_API_KEY=""
PAY4ALL_ENTIDADE="10111"
PAY4ALL_WEBHOOK_SECRET=""
PAY4ALL_VALIDADE_HORAS="72"

# ── Verificação de identidade (KYC) ──────────────────────────────────────────
# Armazenamento das imagens (documentos/selfies). "local" cifra em disco;
# "s3" fica preparado como encaixe para produção (S3 + URLs assinadas).
STORAGE_DRIVER="local"
STORAGE_DIR=""
# Chave dedicada para cifrar os ficheiros (recomendado). Sem ela usa SESSION_SECRET.
STORAGE_SECRET=""
# Fornecedor real de OCR/biometria (ou SIAC). Vazio = revisão manual pelo admin.
VERIFICACAO_PROVIDER_URL=""

# Documentos (BI/Passaporte) que devem ter papel de ADMIN, separados por vírgula.
PSN_ADMIN_DOCS=""

# Ambiente
NODE_ENV="development"
